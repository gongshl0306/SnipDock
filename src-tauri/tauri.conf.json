{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SnipDock",
  "version": "0.1.0",
  "identifier": "com.snipdock.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "SnipDock",
        "width": 1000,
        "height": 640,
        "minWidth": 800,
        "minHeight": 500,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": []
  },
  "plugins": {}
}
